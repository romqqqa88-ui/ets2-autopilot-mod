ui : autopilot.settings.menu {
	area		: 100, 100, 600, 500
	layer		: 20
	my_alpha	: 0.95
	my_template	: "settings.template"
	visible		: false
	
	on_init		: "autopilot.settings_init"
	on_update	: "autopilot.settings_update"
	
	children	: settings.header, settings.tabs, settings.content, settings.footer
	
	settings.header : ui::panel {
		area		: 0, 0, 600, 60
		my_template	: "header.template"
		
		children	: header.title, header.close
		
		header.title : ui::text {
			area		: 20, 15, 500, 30
			text		: "Настройки автопилота"
			font		: "font.large"
			color		: 0xFFFFFF
		}
		
		header.close : ui::button {
			area		: 550, 10, 40, 40
			text		: "X"
			font		: "font.medium"
			on_click	: "autopilot.settings_hide"
		}
	}
	
	settings.tabs : ui::panel {
		area		: 0, 60, 150, 390
		my_template	: "tabs.template"
		
		children	: tab.general, tab.driving, tab.safety, tab.interface, tab.advanced
		
		tab.general : ui::button {
			area		: 10, 10, 130, 40
			text		: "Основные"
			font		: "font.medium"
			on_click	: "autopilot.settings_select_tab"
			tab_name	: "general"
			selected	: true
		}
		
		tab.driving : ui::button {
			area		: 10, 60, 130, 40
			text		: "Вождение"
			font		: "font.medium"
			on_click	: "autopilot.settings_select_tab"
			tab_name	: "driving"
		}
		
		tab.safety : ui::button {
			area		: 10, 110, 130, 40
			text		: "Безопасность"
			font		: "font.medium"
			on_click	: "autopilot.settings_select_tab"
			tab_name	: "safety"
		}
		
		tab.interface : ui::button {
			area		: 10, 160, 130, 40
			text		: "Интерфейс"
			font		: "font.medium"
			on_click	: "autopilot.settings_select_tab"
			tab_name	: "interface"
		}
		
		tab.advanced : ui::button {
			area		: 10, 210, 130, 40
			text		: "Расширенные"
			font		: "font.medium"
			on_click	: "autopilot.settings_select_tab"
			tab_name	: "advanced"
		}
	}
	
	settings.content : ui::panel {
		area		: 150, 60, 450, 390
		my_template	: "content.template"
		
		children	: content.general, content.driving, content.safety, content.interface, content.advanced
		
		-- Вкладка "Основные"
		content.general : ui::panel {
			area		: 0, 0, 450, 390
			visible		: true
			
			children	: general.enabled, general.hotkey, general.activation, general.save
			
			general.enabled : ui::checkbox {
				area		: 20, 20, 400, 30
				text		: "Включить автопилот при запуске игры"
				checked		: false
				on_change	: "autopilot.settings_set_bool"
				setting		: "autopilot.enabled_on_start"
			}
			
			general.hotkey : ui::dropdown {
				area		: 20, 60, 200, 30
				text		: "Горячая клавиша:"
				items[]		: "F5"
				items[]		: "F6"
				items[]		: "F7"
				items[]		: "F8"
				items[]		: "F9"
				selected	: 0
				on_change	: "autopilot.settings_set_hotkey"
				setting		: "autopilot.hotkey_toggle"
			}
			
			general.activation : ui::radiogroup {
				area		: 20, 100, 400, 80
				text		: "Активация автопилота:"
				items[]		: "Только при движении по шоссе"
				items[]		: "На всех дорогах"
				items[]		: "Только вне городов"
				selected	: 0
				on_change	: "autopilot.settings_set_activation"
				setting		: "autopilot.activation_mode"
			}
			
			general.save : ui::button {
				area		: 20, 200, 150, 40
				text		: "Сохранить настройки"
				on_click	: "autopilot.settings_save"
			}
		}
		
		-- Вкладка "Вождение"
		content.driving : ui::panel {
			area		: 0, 0, 450, 390
			visible		: false
			
			children	: driving.speed, driving.distance, driving.aggressiveness, driving.overtaking, driving.parking
			
			driving.speed : ui::slider {
				area		: 20, 20, 400, 40
				text		: "Максимальная скорость: {value}% от ограничения"
				min		: 80.0
				max		: 120.0
				value		: 100.0
				step		: 5.0
				on_change	: "autopilot.settings_set_speed"
				setting		: "autopilot.speed_percent"
			}
			
			driving.distance : ui::slider {
				area		: 20, 80, 400, 40
				text		: "Дистанция до впереди идущего: {value} м"
				min		: 20.0
				max		: 100.0
				value		: 50.0
				step		: 5.0
				on_change	: "autopilot.settings_set_distance"
				setting		: "autopilot.follow_distance"
			}
			
			driving.aggressiveness : ui::slider {
				area		: 20, 140, 400, 40
				text		: "Агрессивность вождения: {value}"
				min		: 0.1
				max		: 1.0
				value		: 0.5
				step		: 0.1
				on_change	: "autopilot.settings_set_aggressiveness"
				setting		: "autopilot.aggressiveness"
			}
			
			driving.overtaking : ui::checkbox {
				area		: 20, 200, 400, 30
				text		: "Разрешить автоматический обгон"
				checked		: true
				on_change	: "autopilot.settings_set_bool"
				setting		: "autopilot.overtaking_enabled"
			}
			
			driving.parking : ui::checkbox {
				area		: 20, 240, 400, 30
				text		: "Автоматическая парковка при прибытии"
				checked		: true
				on_change	: "autopilot.settings_set_bool"
				setting		: "autopilot.automatic_parking"
			}
		}
		
		-- Вкладка "Безопасность"
		content.safety : ui::panel {
			area		: 0, 0, 450, 390
			visible		: false
			
			children	: safety.emergency, safety.traffic_lights, safety.signs, safety.weather, safety.collision
			
			safety.emergency : ui::checkbox {
				area		: 20, 20, 400, 30
				text		: "Экстренное торможение при опасности"
				checked		: true
				on_change	: "autopilot.settings_set_bool"
				setting		: "autopilot.emergency_braking"
			}
			
			safety.traffic_lights : ui::checkbox {
				area		: 20, 60, 400, 30
				text		: "Соблюдать сигналы светофоров"
				checked		: true
				on_change	: "autopilot.settings_set_bool"
				setting		: "autopilot.obey_traffic_lights"
			}
			
			safety.signs : ui::checkbox {
				area		: 20, 100, 400, 30
				text		: "Соблюдать дорожные знаки"
				checked		: true
				on_change	: "autopilot.settings_set_bool"
				setting		: "autopilot.obey_traffic_signs"
			}
			
			safety.weather : ui::dropdown {
				area		: 20, 140, 300, 30
				text		: "Режим в плохую погоду:"
				items[]		: "Нормальный"
				items[]		: "Осторожный"
				items[]		: "Отключить автопилот"
				selected	: 1
				on_change	: "autopilot.settings_set_weather"
				setting		: "autopilot.weather_mode"
			}
			
			safety.collision : ui::slider {
				area		: 20, 190, 400, 40
				text		: "Чувствительность к препятствиям: {value}"
				min		: 0.5
				max		: 2.0
				value		: 1.0
				step		: 0.1
				on_change	: "autopilot.settings_set_collision"
				setting		: "autopilot.collision_sensitivity"
			}
		}
		
		-- Вкладка "Интерфейс"
		content.interface : ui::panel {
			area		: 0, 0, 450, 390
			visible		: false
			
			children	: interface.hud, interface.notifications, interface.sounds, interface.minimap, interface.theme
			
			interface.hud : ui::checkbox {
				area		: 20, 20, 400, 30
				text		: "Показывать HUD автопилота"
				checked		: true
				on_change	: "autopilot.settings_set_bool"
				setting		: "autopilot.show_hud"
			}
			
			interface.notifications : ui::checkbox {
				area		: 20, 60, 400, 30
				text		: "Визуальные уведомления"
				checked		: true
				on_change	: "autopilot.settings_set_bool"
				setting		: "autopilot.show_notifications"
			}
			
			interface.sounds : ui::checkbox {
				area		: 20, 100, 400, 30
				text		: "Звуковые оповещения"
				checked		: true
				on_change	: "autopilot.settings_set_bool"
				setting		: "autopilot.enable_sounds"
			}
			
			interface.minimap : ui::checkbox {
				area		: 20, 140, 400, 30
				text		: "Подсветка полосы на мини-карте"
				checked		: true
				on_change	: "autopilot.settings_set_bool"
				setting		: "autopilot.minimap_lane_highlight"
			}
			
			interface.theme : ui::dropdown {
				area		: 20, 180, 300, 30
				text		: "Тема интерфейса:"
				items[]		: "Стандартная"
				items[]		: "Темная"
				items[]		: "Светлая"
				items[]		: "Контрастная"
				selected	: 0
				on_change	: "autopilot.settings_set_theme"
				setting		: "autopilot.ui_theme"
			}
			
			interface.opacity : ui::slider {
				area		: 20, 230, 400, 40
				text		: "Прозрачность интерфейса: {value}%"
				min		: 30.0
				max		: 100.0
				value		: 90.0
				step		: 5.0
				on_change	: "autopilot.settings_set_opacity"
				setting		: "autopilot.ui_opacity"
			}
		}
		
		-- Вкладка "Расширенные"
		content.advanced : ui::panel {
			area		: 0, 0, 450, 390
			visible		: false
			
			children	: advanced.debug, advanced.logging, advanced.compatibility, advanced.reset, advanced.export
			
			advanced.debug : ui::checkbox {
				area		: 20, 20, 400, 30
				text		: "Режим отладки"
				checked		: false
				on_change	: "autopilot.settings_set_bool"
				setting		: "autopilot.debug_mode"
			}
			
			advanced.logging : ui::checkbox {
				area		: 20, 60, 400, 30
				text		: "Запись логов в файл"
				checked		: true
				on_change	: "autopilot.settings_set_bool"
				setting		: "autopilot.log_to_file"
			}
			
			advanced.compatibility : ui::dropdown {
				area		: 20, 100, 300, 30
				text		: "Режим совместимости:"
				items[]		: "Авто"
				items[]		: "ETS 2"
				items[]		: "ATS"
				items[]		: "Универсальный"
				selected	: 0
				on_change	: "autopilot.settings_set_compatibility"
				setting		: "autopilot.compatibility_mode"
			}
			
			advanced.reset : ui::button {
				area		: 20, 150, 200, 40
				text		: "Сбросить настройки"
				on_click	: "autopilot.settings_reset"
			}
			
			advanced.export : ui::button {
				area		: 240, 150, 200, 40
				text		: "Экспорт настроек"
				on_click	: "autopilot.settings_export"
			}
			
			advanced.version : ui::text {
				area		: 20, 210, 400, 30
				text		: "Версия мода: 1.0.0 | Совместимость: ETS 2 1.52+"
				font		: "font.small"
				color		: 0xAAAAAA
			}
		}
	}
	
	settings.footer : ui::panel {
		area		: 0, 450, 600, 50
		my_template	: "footer.template"
		
		children	: footer.apply, footer.cancel, footer.help
		
		footer.apply : ui::button {
			area		: 350, 10, 100, 30
			text		: "Применить"
			on_click	: "autopilot.settings_apply"
		}
		
		footer.cancel : ui::button {
			area		: 460, 10, 100, 30
			text		: "Отмена"
			on_click	: "autopilot.settings_hide"
		}
		
		footer.help : ui::button {
			area		: 20, 10, 100, 30
			text		: "Справка"
			on_click	: "autopilot.settings_help"
		}
	}
}

-- Шаблоны оформления
ui_template : settings.template {
	background	: "ui/settings_bg.png"
	border		: 2
	border_color	: 0x444488
	rounding	: 10
}

ui_template : header.template {
	background	: "ui/header_bg.png"
	border_bottom	: 2
	border_color	: 0x333377
}

ui_template : tabs.template {
	background	: "ui/tabs_bg.png"
	border_right	: 1
	border_color	: 0x333333
}

ui_template : content.template {
	background	: "ui/content_bg.png"
}

ui_template : footer.template {
	background	: "ui/footer_bg.png"
	border_top	: 1
	border_color	: 0x333333
}

-- Стили для элементов
ui_style : settings.button {
	normal_color	: 0x333366
	hover_color	: 0x444488
	pressed_color	: 0x222255
	text_color	: 0xFFFFFF
	border		: 1
	border_color	: 0x555599
	rounding	: 5
}

ui_style : settings.checkbox {
	box_color	: 0x333366
	check_color	: 0x44FF44
	text_color	: 0xFFFFFF
}

ui_style : settings.slider {
	track_color	: 0x333366
	fill_color	: 0x444488
	thumb_color	: 0x44FF44
	text_color	: 0xFFFFFF
}

ui_style : settings.dropdown {
	background	: 0x333366
	hover_color	: 0x444488
	text_color	: 0xFFFFFF
	border		: 1
	border_color	: 0x555599
}

-- Применение стилей
apply_style : settings.button -> autopilot.settings.menu .ui::button
apply_style : settings.checkbox -> autopilot.settings.menu .ui::checkbox
apply_style : settings.slider -> autopilot.settings.menu .ui::slider
apply_style : settings.dropdown -> autopilot.settings.menu .ui::dropdown