ui : autopilot.panel {
	area		: 50, 50, 300, 200
	layer		: 10
	my_alpha	: 0.9
	my_template	: "autopilot.template"
	
	autopilot_enabled	: false
	autopilot_speed		: 90.0
	autopilot_distance	: 50.0
	autopilot_aggressive	: 0.5
	
	on_init		: "autopilot.ui_init"
	on_update	: "autopilot.ui_update"
	
	children	: autopilot.title, autopilot.toggle, autopilot.speed, autopilot.distance, autopilot.aggressiveness, autopilot.close
	
	autopilot.title : ui::text {
		area		: 10, 10, 280, 30
		text		: "Автопилот ETS 2"
		font		: "font.large"
		color		: 0xFFFFFF
		align		: center
	}
	
	autopilot.toggle : ui::button {
		area		: 10, 50, 280, 40
		text		: "Включить автопилот"
		on_click	: "autopilot.toggle"
		enabled		: true
	}
	
	autopilot.speed : ui::slider {
		area		: 10, 100, 280, 30
		min		: 30.0
		max		: 130.0
		value		: 90.0
		step		: 5.0
		text		: "Ограничение скорости: {value} км/ч"
		on_change	: "autopilot.set_speed"
	}
	
	autopilot.distance : ui::slider {
		area		: 10, 140, 280, 30
		min		: 20.0
		max		: 100.0
		value		: 50.0
		step		: 5.0
		text		: "Дистанция следования: {value} м"
		on_change	: "autopilot.set_distance"
	}
	
	autopilot.aggressiveness : ui::slider {
		area		: 10, 180, 280, 30
		min		: 0.1
		max		: 1.0
		value		: 0.5
		step		: 0.1
		text		: "Агрессивность: {value}"
		on_change	: "autopilot.set_aggressiveness"
	}
	
	autopilot.close : ui::button {
		area		: 10, 220, 280, 30
		text		: "Закрыть"
		on_click	: "autopilot.hide"
	}
}

ui_template : autopilot.template {
	background	: "ui/autopilot_bg.png"
	border		: 1
	border_color	: 0x444444
	rounding	: 5
}